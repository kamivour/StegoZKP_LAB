# =============================================================================
# ZK circuit build artifacts  (generated — do not commit)
# =============================================================================
# Witness files are generated fresh each run
circuits/compiled/build/*.wtns
ImageLevel/circuits/compiled/build/*.wtns

# =============================================================================
# ZK circuit compiled artifacts  (DO commit — pre-built for distribution)
# These are large but required; recipients cannot recompile without circom
# Comment out these lines if you want to exclude them and distribute separately
# =============================================================================
# circuits/compiled/build/*.r1cs
# circuits/compiled/build/*.zkey
# circuits/compiled/build/*.sym
# circuits/compiled/build/*.wasm
# circuits/compiled/build/chaos_zk_stego_verification_key.json

# =============================================================================
# Powers of Tau ceremony files  (large binary files)
# pot12_final.ptau is needed to regenerate .zkey — include if repo size allows
# =============================================================================
artifacts/keys/pot16_0000.ptau
artifacts/keys/pot16_0001.ptau
ImageLevel/artifacts/keys/pot16_0000.ptau
ImageLevel/artifacts/keys/pot16_0001.ptau

